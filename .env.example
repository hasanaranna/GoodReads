# Copy this file to .env and update values as needed.
# Docker Compose automatically reads .env from the project root.

# Backend runtime
NODE_ENV=development
PORT=8080
DATABASE_URL=postgresql://postgres:postgres@db:5432/goodreads
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret

# Google Books API
# Required to avoid shared anonymous quota limits.
GOOGLE_BOOKS_API_KEY=
GOOGLE_BOOKS_BASE_URL=https://www.googleapis.com/books/v1

# Database container
POSTGRES_DB=goodreads
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Frontend watcher (useful for Docker bind mounts)
CHOKIDAR_USEPOLLING=true
